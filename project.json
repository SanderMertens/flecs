{
    "id":"flecs",
    "type":"package",
    "value": {
        "author": "Sander Mertens",
        "description": "Entity Component System written in C99/C++17",
        "amalgamate": [{
            "path": "distr"
        }, {
            "path": "distr",
            "prefix": "flecs_no_addons",
            "disable-flags": [ 
                "FLECS_ALERTS",
                "FLECS_APP",
                "FLECS_CPP",
                "FLECS_DOC",
                "FLECS_EXCLUSIVE_ACCESS",
                "FLECS_JOURNAL",
                "FLECS_JSON",
                "FLECS_HTTP",
                "FLECS_LOG",
                "FLECS_META",
                "FLECS_METRICS",
                "FLECS_MODULE",
                "FLECS_PERF_TRACE",
                "FLECS_PIPELINE",
                "FLECS_REST",
                "FLECS_PARSER",
                "FLECS_QUERY_DSL",
                "FLECS_SCRIPT",
                "FLECS_SCRIPT_MATH",
                "FLECS_SYSTEM",
                "FLECS_STATS",
                "FLECS_TIMER",
                "FLECS_UNITS"
            ]
        }]
    },
    "dependee": {
        "lang.c": {
            "${cfg sanitize}": {
                "defines": ["FLECS_SANITIZE"]
            }
        },
        "lang.cpp": {
            "${cfg sanitize}": {
                "defines": ["FLECS_SANITIZE"]
            }
        }
    },
    "lang.c": {
        "${os linux}": {
            "lib": ["rt", "pthread", "m", "dl"],
            "${cfg debug}": {
                "export-symbols": true
            },
            "${cfg sanitize}": {
                "export-symbols": true
            }
        },
        "${os windows}": {
            "lib": ["ws2_32", "dbgHelp"]
        },
        "${cfg sanitize}": {
            "defines": ["FLECS_SANITIZE"]
        }
    }
}
